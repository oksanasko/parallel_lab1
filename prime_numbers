from numba import jit
import time, os
from threading import Thread

class FindPrime:

    def __init__(self):
        self.result = []  # store primes

    @staticmethod
    @jit(nopython=True, nogil=True)
    def is_prime(n):
        if n <= 1:
            return False
        if n <= 3:
            return True
        if n % 2 == 0 or n % 3 == 0:
            return False
        i = 5
        while i * i <= n:
            if n % i == 0 or n % (i + 2) == 0:
                return False
            i += 6
        return True

    def primes_in_range(self, start, end):
        local_primes = []
        for n in range(start, end):
            if self.is_prime(n):
                local_primes.append(n)
        self.result = local_primes  # store result


if __name__ == "__main__":
    start_time = time.time()

    num_start = 1
    num_finish = 10000
    num_threads = os.cpu_count()

    part_size = (num_finish - num_start) // num_threads

    find_primes = []
    threads = []

    for i in range(num_threads):
        fp = FindPrime()
        find_primes.append(fp)

        start_range = num_start + i * part_size
        end_range = num_start + (i + 1) * part_size

        if i == num_threads - 1:
            end_range = num_finish  # last thread takes remainder

        thread = Thread(target=fp.primes_in_range, args=(start_range, end_range))
        threads.append(thread)

        print(f"Started thread {i}: {start_range} → {end_range}")

    for thread in threads:
        thread.start()

    for thread in threads:
        thread.join()

    #  results
    all_primes = []
    for fp in find_primes:
        all_primes.extend(fp.result)

    end_time = time.time()

    print(f"Found {len(all_primes)} primes")
    print(f"Time: {end_time - start_time:.7f}s")
