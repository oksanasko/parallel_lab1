import multiprocessing
import time
from numba import jit


class FindPrime:
    @staticmethod

    def is_prime(n):
        if n <= 1:
            return False
        if n <= 3:
            return True
        if n % 2 == 0 or n % 3 == 0:
            return False
        i = 5
        while i * i <= n:
            if n % i == 0 or n % (i + 2) == 0:
                return False
            i += 6
        return True

    @staticmethod
    def primes_in_range(start, end):
        primes = []
        for n in range(start, end):
            if FindPrime.is_prime(n):
                primes.append(n)
        return primes


# worker for multiprocessing
def worker(start, end):
    return FindPrime.primes_in_range(start, end)

def run_prime_experiments(num_start, num_finish, process_counts):
    results = []

    total_numbers = num_finish - num_start

    for num_proc in process_counts:
        # Split work evenly
        chunk_size = total_numbers // num_proc
        ranges = []
        start = num_start
        for i in range(num_proc):
            end = start + chunk_size
            if i == num_proc - 1:
                end = num_finish  # last process takes remainder
            ranges.append((start, end))
            start = end

        print(f"\nRunning with {num_proc} processes...")
        start_time = time.time()

        pool = multiprocessing.Pool(processes=num_proc)
        async_results = [pool.apply_async(worker, args=r) for r in ranges]
        pool.close()
        pool.join()

        # Collect all primes
        all_primes = []
        for r in async_results:
            all_primes.extend(r.get())

        elapsed = time.time() - start_time
        print(f"Processes = {num_proc:2d} | Primes found = {len(all_primes)} | time = {elapsed:.5f}s")
        results.append((num_finish - num_start, num_proc, len(all_primes), elapsed))

    return results


if __name__ == "__main__":
    num_start = 1
    num_finish = 3_000_000  # 
    print(f" for {num_finish}")
    process_counts = [1, 2, 4, 8, 16]  # 

    results = run_prime_experiments(num_start, num_finish, process_counts)
