import numpy as np
import time
from threading import Thread
from numba import jit


class MatrixTranspose:
    def __init__(self):
        self.result = None

    @staticmethod
    def generate_matrix(size=10_000):
        return np.random.randint(0, 100, size=(size, size), dtype=np.int8)

    @staticmethod
    def split_parts(n, num_threads):
        part_size = n // num_threads
        parts = []

        for i in range(num_threads):
            start = i * part_size
            end = (i + 1) * part_size

            if i == num_threads - 1:
                end = n  # last part takes the remainder

            parts.append((start, end))

        return parts

    @staticmethod
    @jit(nopython=True, nogil=True)
    def transpose_part(mat, result, start_row, end_row):
        n = mat.shape[0]
        for i in range(start_row, end_row):
            for j in range(n):
                result[j, i] = mat[i, j]

    def transpose_in_threads(self, mat, num_threads=4):
        n = mat.shape[0]
        self.result = np.zeros((n, n), dtype=mat.dtype)

        parts = self.split_parts(n, num_threads)

        threads = []

        for idx, (start_row, end_row) in enumerate(parts):
            thread = Thread(
                target=MatrixTranspose.transpose_part,
                args=(mat, self.result, start_row, end_row)
            )
            threads.append(thread)
            #print(f"Started thread {idx}: rows {start_row} → {end_row}")

        for thread in threads:
            thread.start()

        for thread in threads:
            thread.join()

        return self.result


def run_transpose_experiments(matrix_sizes, thread_counts):
    results = []

    for size in matrix_sizes:
        print(f"\n--- Matrix size = {size} x {size} ---")
        mat = MatrixTranspose.generate_matrix(size)

        for num_threads in thread_counts:
            mt = MatrixTranspose()
            start_time = time.time()
            result = mt.transpose_in_threads(mat, num_threads=num_threads)
            elapsed = time.time() - start_time

            correct = np.allclose(result, mat.T)
            print(f"Threads = {num_threads:2d} | Time = {elapsed:.4f}s | Correct = {correct}")

            results.append((size, num_threads, elapsed, correct))

    return results


if __name__ == "__main__":
    matrix_sizes = [10_000, 15_000, 20_000]  # smaller sizes for quick testing
    thread_counts = [1, 2, 4, 8, 16]         # number of threads

    results = run_transpose_experiments(matrix_sizes, thread_counts)
