import multiprocessing
import numpy as np
import time
import math
from numba import jit


class FindPi:
    @staticmethod
    def throw_points(nn):
        inside = 0
        for _ in range(nn):
            x = np.random.uniform(-1,1)
            y = np.random.uniform(-1,1)
            if x**2 + y**2 <= 1:
                inside += 1
        return inside, nn

# Worker function for multiprocessing
def worker(nn):
    return FindPi.throw_points(nn)


def run_experiments(total_points_list, process_counts):
    results = []

    for N in total_points_list:
        print(f"\n--- Total points = {N} ---")
        for num_proc in process_counts:
            points_per_proc = N // num_proc

            start_time = time.time()

            pool = multiprocessing.Pool(processes=num_proc)
            async_results = [pool.apply_async(worker, args=(points_per_proc,)) for _ in range(num_proc)]
            pool.close()
            pool.join()

            inside_total = 0
            total_points_actual = 0
            for r in async_results:
                i, n = r.get()
                inside_total += i
                total_points_actual += n

            pi_estimate = 4 * inside_total / total_points_actual
            elapsed = time.time() - start_time

            print(f"Processes = {num_proc:2d} | pi ≈ {pi_estimate:.6f} | time = {elapsed:.4f}s")
            results.append((N, num_proc, pi_estimate, elapsed))
    return results

if __name__ == "__main__":
    # different total numbers of points
    total_points_list = [50_000, 500_000, 2_000_000]  

    # Try different numbers of processes
    process_counts = [1, 2, 4, 8, 16]  # 

    results = run_experiments(total_points_list, process_counts)
